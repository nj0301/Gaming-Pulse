# ── Strapi core secrets (generate fresh values per environment; never commit real ones) ──
# Generate each with: openssl rand -base64 32
HOST=0.0.0.0
PORT=1337
APP_KEYS=changeMe1,changeMe2,changeMe3,changeMe4
API_TOKEN_SALT=changeMe
ADMIN_JWT_SECRET=changeMe
TRANSFER_TOKEN_SALT=changeMe
JWT_SECRET=changeMe
ENCRYPTION_KEY=changeMe

# Public URL of this CMS (used for absolute media URLs behind a proxy/CDN)
PUBLIC_URL=

# ── Database ──
# Local development default: sqlite (zero setup).
# Production: set DATABASE_CLIENT=postgres and the connection details below
# (or a single DATABASE_URL). See docker-compose.yml for a local Postgres.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://strapi:strapi@localhost:5432/gaming_pulse
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=gaming_pulse
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SSL=false

# ── CORS: comma-separated origins allowed to call the API ──
CORS_ORIGINS=http://localhost:3000

# ── Background jobs ──
CRON_ENABLED=true
# REDIS_URL=redis://localhost:6379   # optional: shared cache/queue for multi-instance deployments

# ── Media/CDN ──
# Host allowed in the CMS Content-Security-Policy for externally stored media,
# e.g. your S3/Cloudinary domain. Leave empty when using local uploads.
MEDIA_CDN_HOST=

# ── External data providers (all optional; adapters stay disabled when unset) ──
# Validate commercial usage rights before enabling any provider.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Comma-separated allowlist of publisher press RSS feeds (leads only, never auto-published)
RSS_FEEDS=
