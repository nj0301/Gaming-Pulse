{
  "kind": "collectionType",
  "collectionName": "trends",
  "info": { "singularName": "trend", "pluralName": "trends", "displayName": "Trend", "description": "Trending topic with score, explanation and editorial controls" },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "whyTrending": { "type": "text", "required": true },
    "context": { "type": "text" },
    "score": { "type": "decimal", "default": 0 },
    "pinned": { "type": "boolean", "default": false },
    "hidden": { "type": "boolean", "default": false },
    "manualAdjustment": { "type": "integer", "default": 0, "min": -100, "max": 100 },
    "editorialSignificance": { "type": "integer", "default": 50, "min": 0, "max": 100 },
    "expiresAt": { "type": "datetime" },
    "relatedArticles": { "type": "relation", "relation": "manyToMany", "target": "api::article.article" },
    "relatedGames": { "type": "relation", "relation": "manyToMany", "target": "api::game.game" },
    "relatedVideos": { "type": "relation", "relation": "manyToMany", "target": "api::video.video" },
    "signals": { "type": "json" }
  }
}
