{
  "kind": "collectionType",
  "collectionName": "platforms",
  "info": { "singularName": "platform", "pluralName": "platforms", "displayName": "Platform" },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "shortName": { "type": "string" },
    "description": { "type": "text" },
    "accent": { "type": "enumeration", "enum": ["cyan", "violet", "magenta", "green", "warning"], "default": "cyan" },
    "articles": { "type": "relation", "relation": "manyToMany", "target": "api::article.article", "mappedBy": "platforms" },
    "games": { "type": "relation", "relation": "manyToMany", "target": "api::game.game", "mappedBy": "platforms" }
  }
}
