{
  "kind": "collectionType",
  "collectionName": "companies",
  "info": { "singularName": "company", "pluralName": "companies", "displayName": "Company", "description": "Studios and publishers" },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "name", "required": true },
    "role": { "type": "enumeration", "enum": ["developer", "publisher", "both"], "default": "developer" },
    "country": { "type": "string" },
    "founded": { "type": "integer" },
    "description": { "type": "text" },
    "developedGames": { "type": "relation", "relation": "oneToMany", "target": "api::game.game", "mappedBy": "developer" },
    "publishedGames": { "type": "relation", "relation": "oneToMany", "target": "api::game.game", "mappedBy": "publisher" }
  }
}
